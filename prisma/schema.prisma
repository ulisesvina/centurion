// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum CallStatus {
  PENDING    // esperando que el bot procese
  ACTIVE     // bot tomando la llamada
  CLASSIFIED // IA clasificó la emergencia
  RESOLVED   // caso cerrado
  ABANDONED  // el ciudadano colgó
}

enum EmergencyType {
  MEDICAL
  CRIME
  ACCIDENT
  OTHER
}

enum Priority {
  CRITICAL   // vida en peligro inmediato → va directo a operador
  HIGH       // urgente
  MEDIUM     // importante
  LOW        // no urgente
  IRRELEVANT // llamada falsa o que no requiere atención
}

enum EmergencyStatus {
  PENDING     // sin asignar
  ASSIGNED    // operador asignado
  IN_PROGRESS // operador atendiendo
  RESOLVED    // resuelto
}

enum OperatorStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// ─────────────────────────────────────────────
// MODELOS
// ─────────────────────────────────────────────

// Ciudadano registrado en la app
model User {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String    @unique
  phoneNumber  String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions  Session[]
  addresses Address[]
  calls     Call[]
}

// Sesión activa de un usuario (expira)
model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime // si now() > expiresAt → sesión inválida
  createdAt DateTime @default(now())
}

// Dirección estructurada (México)
model Address {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  street       String  // nombre de la calle
  extNumber    String  // número exterior
  intNumber    String? // número interior (Depto, Piso, etc.)
  neighborhood String  // colonia
  city         String  // ciudad o municipio
  state        String  // estado (ej. "Ciudad de México", "Jalisco")
  postalCode   String  // código postal (5 dígitos en México)
  country      String  @default("México")
  references   String? // referencias adicionales (ej. "entre Calle X y Calle Y")
  latitude     Float?  // coordenadas opcionales para el mapa
  longitude    Float?

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  emergencies Emergency[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Llamada entrante del ciudadano
model Call {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  phoneNumber String
  status      CallStatus @default(PENDING)
  transcript  String?    // conversación completa con el bot de IA
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  emergency Emergency?
}

// Emergencia clasificada por la IA a partir de la llamada
model Emergency {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  callId      String          @unique @db.ObjectId
  call        Call            @relation(fields: [callId], references: [id])

  type        EmergencyType
  priority    Priority
  description String          // resumen generado por la IA
  status      EmergencyStatus @default(PENDING)

  // Ubicación del incidente — dirección estructurada o coordenadas GPS
  addressId String?  @db.ObjectId
  address   Address? @relation(fields: [addressId], references: [id])
  latitude  Float?
  longitude Float?

  aiMetadata Json? // datos crudos del modelo de IA (scores, confianza, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment Assignment?
}

// Operador humano del 911
model Operator {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String         @unique
  badgeNumber  String         @unique
  passwordHash String
  status       OperatorStatus @default(OFFLINE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  assignments      Assignment[]
  operatorSessions OperatorSession[]
}

// Sesión activa de un operador (expira)
model OperatorSession {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  token      String   @unique
  operatorId String   @db.ObjectId
  operator   Operator @relation(fields: [operatorId], references: [id])
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

// Asignación de una emergencia a un operador
model Assignment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  emergencyId String    @unique @db.ObjectId
  emergency   Emergency @relation(fields: [emergencyId], references: [id])
  operatorId  String    @db.ObjectId
  operator    Operator  @relation(fields: [operatorId], references: [id])

  assignedAt DateTime  @default(now())
  resolvedAt DateTime?
  notes      String?   // notas del operador al cerrar el caso
}
