// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum CallStatus {
  PENDING    // esperando que el bot procese
  ACTIVE     // bot tomando la llamada
  CLASSIFIED // IA clasificó la emergencia
  RESOLVED   // caso cerrado
  ABANDONED  // el ciudadano colgó
}

enum EmergencyType {
  MEDICAL
  FIRE
  CRIME
  ACCIDENT
  NATURAL_DISASTER
  OTHER
}

enum Priority {
  CRITICAL   // vida en peligro inmediato → va directo a operador
  HIGH       // urgente
  MEDIUM     // importante
  LOW        // no urgente
  IRRELEVANT // llamada falsa o que no requiere atención
}

enum EmergencyStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum OperatorStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// ─────────────────────────────────────────────
// MODELOS
// ─────────────────────────────────────────────

model User {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  address Address[]
  calls   Call[]
}

model Operator {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String         @unique
  badgeNumber String         @unique
  status      OperatorStatus @default(OFFLINE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  assignments Assignment[]
}

model Address {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  street       String
  extNumber    String
  intNumber    String?
  neighborhood String
  city         String
  state        String
  postalCode   String
  country      String  @default("México")
  references   String?
  latitude     Float?
  longitude    Float?

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emergencies Emergency[]
}

model Call {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  phoneNumber String
  status      CallStatus @default(PENDING)
  transcript  String?

  userId String? @db.ObjectId
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emergency Emergency?
}

model Emergency {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  callId String @unique @db.ObjectId
  call   Call   @relation(fields: [callId], references: [id])

  type        EmergencyType
  priority    Priority
  description String
  status      EmergencyStatus @default(PENDING)

  addressId String?  @db.ObjectId
  address   Address? @relation(fields: [addressId], references: [id])
  latitude  Float?
  longitude Float?

  aiMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignment Assignment?
}

model Assignment {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  emergencyId String    @unique @db.ObjectId
  emergency   Emergency @relation(fields: [emergencyId], references: [id])
  operatorId  String    @db.ObjectId
  operator    Operator  @relation(fields: [operatorId], references: [id])

  assignedAt DateTime  @default(now())
  resolvedAt DateTime?
  notes      String?
}
